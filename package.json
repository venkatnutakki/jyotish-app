{
  "name": "jyotish-app",
  "version": "0.1.0",
  "private": true,
  "author": "Jyotish",
  "description": "Jyotish — Vedic astrology desktop app",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "desktop:prepare": "next build && node electron/prepare.js",
    "desktop:dev": "npm run desktop:prepare && electron .",
    "desktop:build": "npm run desktop:prepare && electron-builder --win --x64",
    "gen:cities": "node scripts/gen-cities.mjs",
    "gen:icons": "node scripts/gen-icons.mjs",
    "mobile:assets": "npm run gen:icons && capacitor-assets generate --android",
    "mobile:build": "node scripts/build-mobile.mjs",
    "mobile:open": "cap open android"
  },
  "build": {
    "appId": "com.jyotish.app",
    "productName": "Jyotish",
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "standalone/node_modules"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "Jyotish"
    }
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "all-the-cities": "^3.1.0",
    "astronomy-engine": "^2.1.19",
    "city-timezones": "^1.3.4",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
